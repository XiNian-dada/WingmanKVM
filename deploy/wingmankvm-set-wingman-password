#!/bin/sh
set -eu

# This helper is installed root-owned and is only callable through the
# matching sudoers rule.  It deliberately accepts the password on stdin so
# it never appears in argv or the process list.
IFS= read -r password || true
[ -n "$password" ] || exit 2
printf 'wingman:%s\n' "$password" | /usr/sbin/chpasswd
