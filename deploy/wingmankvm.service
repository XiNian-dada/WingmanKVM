[Unit]
Description=WingmanKVM lightweight ARM KVM service
After=network-online.target wingmankvm-gadget.service
Wants=network-online.target wingmankvm-gadget.service

[Service]
Type=simple
User=wingmankvm
Group=wingmankvm
SupplementaryGroups=wingmankvm-hw
Environment=WINGMANKVM_STATE_DIR=/var/lib/wingmankvm
Environment=RUST_LOG=wingmankvm=info
ExecStart=/usr/local/bin/wingmankvm
Restart=on-failure
RestartSec=2s
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/wingmankvm -/sys/kernel/config/usb_gadget

[Install]
WantedBy=multi-user.target
