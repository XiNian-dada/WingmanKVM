# Installed as /etc/wingmankvm/gadget.env. Every value is optional.

# Leave empty to select the first free UDC. Set this only on boards with more
# than one Device Controller when a specific OTG port must be used.
WINGMANKVM_GADGET_UDC=
WINGMANKVM_GADGET_UDC_WAIT_SECONDS=15

# Some boards expose a role-switch attribute that must be set to "device"
# before a UDC appears. Leave the path empty on systems that switch roles
# automatically. The path is board/kernel specific and is intentionally not
# guessed here.
WINGMANKVM_USB_ROLE_PATH=
WINGMANKVM_USB_ROLE_VALUE=device

# The Gadget name is a configfs directory name, not a board-specific path.
WINGMANKVM_GADGET_NAME=wingmankvm

# Replace these example IDs with IDs assigned to your product before shipping
# hardware commercially. The defaults are suitable for local development.
WINGMANKVM_GADGET_ID_VENDOR=0x1d6b
WINGMANKVM_GADGET_ID_PRODUCT=0x0104
WINGMANKVM_GADGET_BCD_DEVICE=0x0100
WINGMANKVM_GADGET_BCD_USB=0x0200

WINGMANKVM_GADGET_MANUFACTURER=WingmanKVM
WINGMANKVM_GADGET_PRODUCT="WingmanKVM USB KVM"
# Empty derives a stable serial from /etc/machine-id.
WINGMANKVM_GADGET_SERIAL=
WINGMANKVM_GADGET_CONFIGURATION="Keyboard, pointers and virtual media"
WINGMANKVM_GADGET_MAX_POWER=250
WINGMANKVM_GADGET_BM_ATTRIBUTES=0x80

WINGMANKVM_GADGET_HW_GROUP=wingmankvm-hw
WINGMANKVM_GADGET_KEYBOARD_LINK=wingmankvm-keyboard
WINGMANKVM_GADGET_MOUSE_LINK=wingmankvm-mouse
WINGMANKVM_GADGET_ABSOLUTE_LINK=wingmankvm-absolute
